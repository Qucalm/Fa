// 获取页面元素
const cnBtn = document.getElementById('cnBtn');
const enBtn = document.getElementById('enBtn');
const langElements = document.querySelectorAll('.lang');

// 切换语言函数
function setLanguage(langCode) {
    langElements.forEach(el => {
        const key = el.getAttribute('data-key');
        if (lang[key] && lang[key][langCode]) {
            // 处理带HTML的内容（如aboutDesc的<br>）
            el.innerHTML = lang[key][langCode];
        }
    });
    // 切换按钮激活状态
    cnBtn.classList.toggle('active', langCode === 'cn');
    enBtn.classList.toggle('active', langCode === 'en');
    // 修改页面语言属性
    document.documentElement.lang = langCode === 'cn' ? 'zh-CN' : 'en';
}

// 初始加载中文
window.onload = () => setLanguage('cn');

// 绑定语言切换按钮事件
cnBtn.addEventListener('click', () => setLanguage('cn'));
enBtn.addEventListener('click', () => setLanguage('en'));
